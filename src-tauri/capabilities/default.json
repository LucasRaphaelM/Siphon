{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:menu:default",
    "core:tray:default",
    "core:event:default",
    "core:path:default",
    "core:window:allow-start-dragging",
    "shell:allow-execute",
    "fs:allow-exists",
    "fs:allow-stat",
    "dialog:default"
  ]
}