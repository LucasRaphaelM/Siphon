{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "siphon",
  "version": "1.0.0",
  "identifier": "com.siphon.br",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "siphon",
        "width": 350,
        "height": 700,
        "resizable": false,
        "fullscreen": false,
        "skipTaskbar": true,
        "decorations" : false,
        "visible" : false,
        "alwaysOnTop": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPDATA/Siphon/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/cloudflared"
    ]
  }
}
